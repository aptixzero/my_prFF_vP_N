<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================= -->
<!-- v4.6 DONATE / SUPPORT tab — replaces the old Sponsor tab.     -->
<!-- Shows admin-controlled crypto donation options: each row is   -->
<!-- [logo] · [address] · [copy]. Fully panel-driven.              -->
<!-- ============================================================= -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="18dp"
    android:paddingTop="12dp"
    android:paddingBottom="14dp">

    <TextView
        android:id="@+id/donate_heading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/donate_heading"
        android:textColor="@color/violet_bright"
        android:textSize="19sp"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        android:shadowColor="@color/violet"
        android:shadowDx="0" android:shadowDy="0" android:shadowRadius="16" />

    <TextView
        android:id="@+id/donate_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/donate_note"
        android:textColor="?attr/appTextSecondary"
        android:textSize="12sp"
        android:lineSpacingExtra="3dp"
        android:layout_marginTop="6dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/empty_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/donate_empty"
            android:textColor="?attr/appTextDim"
            android:textSize="14sp" />
    </FrameLayout>
</LinearLayout>
