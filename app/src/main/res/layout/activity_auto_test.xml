<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================= -->
<!-- v4.6 AUTO TEST probe page — opens when the user taps AUTO      -->
<!-- TEST. Deliberately minimal: a title, an animated progress bar  -->
<!-- and nothing else (no per-source text). It runs the fast        -->
<!-- ConnectivityProbe, closes on the FIRST working vless+vmess,    -->
<!-- then hands off to the continuous AutoTestEngine.               -->
<!-- ============================================================= -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBgDrawable">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_bolt"
            app:tint="@color/violet_bright"
            android:layout_marginBottom="20dp"
            android:contentDescription="@string/auto_test" />

        <TextView
            android:id="@+id/probe_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/autotest_probe_title"
            android:textColor="?attr/appTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.04" />

        <ProgressBar
            android:id="@+id/probe_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="26dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/neon_progress" />

        <TextView
            android:id="@+id/probe_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="@color/violet_bright"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp" />

        <TextView
            android:id="@+id/btn_probe_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:textColor="?attr/appTextSecondary"
            android:textSize="13sp"
            android:padding="14dp"
            android:layout_marginTop="18dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>
</FrameLayout>
