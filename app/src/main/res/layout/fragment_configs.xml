<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="18dp"
    android:paddingTop="10dp"
    android:paddingBottom="14dp">

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/configs_title"
            android:textColor="@color/violet_bright"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.18"
            android:shadowColor="@color/violet"
            android:shadowDx="0" android:shadowDy="0" android:shadowRadius="18" />

        <TextView
            android:id="@+id/btn_select_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_mode"
            android:textColor="@color/violet_bright"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:background="@drawable/btn_outline"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/configs_hint"
        android:textColor="?attr/appTextSecondary"
        android:textSize="11sp"
        android:layout_marginTop="4dp" />

    <!-- Paste button -->
    <TextView
        android:id="@+id/btn_paste"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/paste_clipboard"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:background="@drawable/connect_pill_idle"
        android:clickable="true"
        android:focusable="true" />

    <!-- Action toolbar: ping all (always) + select-mode actions -->
    <LinearLayout
        android:id="@+id/action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:weightSum="4">

        <TextView
            android:id="@+id/btn_ping_all"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/ping_all"
            android:textColor="@color/violet_bright"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_secondary"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_select_all"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/select_all"
            android:textColor="@color/violet_bright"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_outline"
            android:layout_marginEnd="6dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_copy_sel"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/copy_selected"
            android:textColor="@color/neon_blue"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_outline"
            android:layout_marginEnd="6dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_delete_sel"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/delete_selected"
            android:textColor="@color/state_danger"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_danger"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- v6.2 — PING ALL sweep progress bar (shown only while pinging) -->
    <LinearLayout
        android:id="@+id/sweep_box"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/sweep_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/neon_progress" />

        <TextView
            android:id="@+id/sweep_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text=""
            android:textColor="?attr/appTextSecondary"
            android:textSize="11sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="14dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/empty_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/empty_configs"
            android:textColor="?attr/appTextDim"
            android:textSize="14sp"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
