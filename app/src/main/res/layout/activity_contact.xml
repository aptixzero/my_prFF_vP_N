<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBgDrawable">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- top bar with back + title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/appPanelColor"
            android:paddingHorizontal="10dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="?attr/appTextPrimary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/close"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/contact_title"
                android:textColor="?attr/appTextPrimary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="24dp">

                <!-- contact body card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/stat_chip"
                    android:padding="22dp"
                    android:layout_marginTop="20dp">

                    <TextView
                        android:id="@+id/contact_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/contact_default_text"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="15sp"
                        android:lineSpacingExtra="6dp" />

                    <TextView
                        android:id="@+id/contact_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@mx_pr"
                        android:textColor="?attr/appAccentGreen"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginTop="16dp" />
                </LinearLayout>

                <!-- two action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="22dp"
                    android:weightSum="2">

                    <TextView
                        android:id="@+id/btn_copy_id"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/contact_copy_id"
                        android:textColor="?attr/appTextPrimary"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:background="@drawable/btn_outline"
                        android:layout_marginEnd="7dp" />

                    <TextView
                        android:id="@+id/btn_send_msg"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/contact_send_msg"
                        android:textColor="#04120B"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:background="@drawable/btn_neon"
                        android:layout_marginStart="7dp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
