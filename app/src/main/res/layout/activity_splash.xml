<?xml version="1.0" encoding="utf-8"?>
<!-- Premium dark startup: pure black, centered white LOADING title, thin white
     progress bar beneath. No matrix / binary / falling characters / noise. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="44dp">

        <!-- centered white title — the loading glyph -->
        <TextView
            android:id="@+id/boot_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_loading"
            android:textColor="#FFFFFFFF"
            android:textSize="40sp"
            android:textStyle="bold"
            android:letterSpacing="0.30"
            android:shadowColor="#66FFFFFF"
            android:shadowDx="0" android:shadowDy="0" android:shadowRadius="24"
            android:fontFeatureSettings="liga 0" />

        <!-- thin white progress bar -->
        <ProgressBar
            android:id="@+id/boot_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="220dp"
            android:layout_height="3dp"
            android:layout_marginTop="34dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/boot_progress" />

        <!-- subtle status line (kept minimal, monochrome) -->
        <TextView
            android:id="@+id/boot_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text=""
            android:textColor="#66FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.18" />

        <!-- hidden percent (kept so SplashActivity can still bind it) -->
        <TextView
            android:id="@+id/boot_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
