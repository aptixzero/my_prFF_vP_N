<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBgDrawable">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/appPanelColor"
            android:paddingHorizontal="10dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="?attr/appTextPrimary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/close" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_title"
                android:textColor="?attr/appTextPrimary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Theme -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme"
                    android:textColor="?attr/appAccentGreen"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:weightSum="2">

                    <TextView
                        android:id="@+id/opt_theme_dark"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/theme_dark"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/btn_outline"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/opt_theme_light"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/theme_light"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/btn_outline"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Language -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_language"
                    android:textColor="?attr/appAccentGreen"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:weightSum="2">

                    <TextView
                        android:id="@+id/opt_lang_fa"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/lang_fa"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/btn_outline"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/opt_lang_en"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/lang_en"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/btn_outline"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- v6.2 — Privacy / paste-history section REMOVED from the UI.
                     The feature stays ON by default (AppPrefs) so paste-from-
                     clipboard keeps scanning the on-device history invisibly;
                     the user just never sees the toggle or the clear button. -->

                <!-- About -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_about"
                    android:textColor="?attr/appAccentGreen"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="24dp" />

                <TextView
                    android:id="@+id/about_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/appTextSecondary"
                    android:textSize="13sp"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:id="@+id/about_core"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/appTextSecondary"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
