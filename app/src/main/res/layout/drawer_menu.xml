<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="288dp"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/appPanelColor"
    android:paddingTop="28dp">

    <!-- header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingVertical="20dp"
        android:paddingHorizontal="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_brand"
            android:textColor="?attr/appTextPrimary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:shadowColor="@color/neon_green"
            android:shadowDx="0" android:shadowDy="0" android:shadowRadius="18" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_title"
            android:textColor="?attr/appAccentRed"
            android:textSize="10sp"
            android:letterSpacing="0.3"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/appStroke" />

    <!-- Theme toggle row -->
    <LinearLayout
        android:id="@+id/menu_theme"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_theme"
            app:tint="?attr/appAccentGreen"
            android:contentDescription="@string/menu_theme" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/menu_theme"
            android:textColor="?attr/appTextPrimary"
            android:textSize="15sp"
            android:layout_marginStart="16dp" />

        <TextView
            android:id="@+id/menu_theme_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/appTextSecondary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Language toggle row -->
    <LinearLayout
        android:id="@+id/menu_language"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_language"
            app:tint="?attr/appAccentGreen"
            android:contentDescription="@string/menu_language" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/menu_language"
            android:textColor="?attr/appTextPrimary"
            android:textSize="15sp"
            android:layout_marginStart="16dp" />

        <TextView
            android:id="@+id/menu_language_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/appTextSecondary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Settings row -->
    <LinearLayout
        android:id="@+id/menu_settings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_settings"
            app:tint="?attr/appAccentGreen"
            android:contentDescription="@string/menu_settings" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/menu_settings"
            android:textColor="?attr/appTextPrimary"
            android:textSize="15sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- Contact Us row -->
    <LinearLayout
        android:id="@+id/menu_contact"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_contact"
            app:tint="?attr/appAccentGreen"
            android:contentDescription="@string/menu_contact" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/menu_contact"
            android:textColor="?attr/appTextPrimary"
            android:textSize="15sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>
</LinearLayout>
