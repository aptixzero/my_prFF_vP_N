<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ===== Main content ===== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/appBgDrawable">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Top app bar: brand (start) + hamburger (top-right/end) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/app_brand"
                    android:textColor="?attr/appTextPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:shadowColor="@color/neon_green"
                    android:shadowDx="0" android:shadowDy="0" android:shadowRadius="16" />

                <ImageView
                    android:id="@+id/btn_menu"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:padding="9dp"
                    android:src="@drawable/ic_menu"
                    app:tint="?attr/appAccentGreen"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/menu" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/fragment_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Bottom tab bar (compact 48dp, 4 tabs) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="@drawable/tab_bar_bg">

                <TextView
                    android:id="@+id/nav_connect"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/tab_home"
                    android:textColor="@color/tab_text"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:background="@drawable/tab_item_bg"
                    android:foreground="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/nav_configs"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/configs"
                    android:textColor="@color/tab_text"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:background="@drawable/tab_item_bg"
                    android:foreground="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/nav_free"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/free_configs"
                    android:textColor="@color/tab_text"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:background="@drawable/tab_item_bg"
                    android:foreground="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/nav_sponsor"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/sponsor_configs"
                    android:textColor="@color/tab_text"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:background="@drawable/tab_item_bg"
                    android:foreground="?attr/selectableItemBackground" />
            </LinearLayout>
        </LinearLayout>

        <!-- very faint static texture overlay (non-interactive, no flashing) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/scanlines"
            android:alpha="0.03"
            android:clickable="false"
            android:focusable="false" />
    </FrameLayout>

    <!-- ===== Side drawer (opens from the END / right) ===== -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_drawer"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:fitsSystemWindows="true"
        app:insetForeground="@android:color/transparent">

        <include layout="@layout/drawer_menu" />
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>
