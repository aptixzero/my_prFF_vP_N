<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="18dp"
    android:paddingTop="10dp"
    android:paddingBottom="14dp">

    <TextView
        android:id="@+id/sponsor_heading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/sponsor_title"
        android:textColor="@color/violet_bright"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.18"
        android:shadowColor="@color/violet"
        android:shadowDx="0" android:shadowDy="0" android:shadowRadius="16" />

    <TextView
        android:id="@+id/sponsor_note"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sponsor_hint"
        android:textColor="?attr/appTextSecondary"
        android:textSize="11sp"
        android:layout_marginTop="4dp" />

    <!-- Ping All (the only batch action available on restricted sponsor configs) -->
    <TextView
        android:id="@+id/btn_ping_all"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/ping_all"
        android:textColor="@color/violet_bright"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        android:background="@drawable/btn_outline"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:id="@+id/progress_box"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/search_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/boot_progress" />

        <TextView
            android:id="@+id/progress_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text=""
            android:textColor="?attr/appTextSecondary"
            android:textSize="11sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="14dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/empty_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/sponsor_cta"
            android:textColor="?attr/appTextDim"
            android:textSize="14sp" />
    </FrameLayout>
</LinearLayout>
