<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="18dp"
    android:paddingTop="10dp"
    android:paddingBottom="14dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/free_title"
        android:textColor="?attr/appAccentGreen"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.18"
        android:shadowColor="@color/violet"
        android:shadowDx="0" android:shadowDy="0" android:shadowRadius="16" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/free_hint"
        android:textColor="?attr/appTextSecondary"
        android:textSize="11sp"
        android:layout_marginTop="4dp" />

    <!-- SEARCH FREE CONFIGS (primary, +100 per press) -->
    <TextView
        android:id="@+id/btn_search"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/search_free_configs"
        android:textColor="#FF00150A"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:background="@drawable/btn_neon"
        android:clickable="true"
        android:focusable="true" />

    <!-- progress bar + label (visible during search) -->
    <LinearLayout
        android:id="@+id/progress_box"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/search_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/boot_progress" />

        <TextView
            android:id="@+id/progress_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text=""
            android:textColor="?attr/appTextSecondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Action toolbar: Ping All · Select · Delete All -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:weightSum="3">

        <TextView
            android:id="@+id/btn_ping_all"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/ping_all"
            android:textColor="?attr/appAccentGreen"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_outline"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_select"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/select_mode"
            android:textColor="@color/violet_bright"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_outline"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_delete_all"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/delete_all"
            android:textColor="@color/neon_red"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_outline"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Select-mode toolbar: Select All · Copy · Delete (hidden until select on) -->
    <LinearLayout
        android:id="@+id/select_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:weightSum="3"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_select_all"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/select_all"
            android:textColor="@color/violet_bright"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_outline"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_copy_sel"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/copy_selected"
            android:textColor="?attr/appAccentGreen"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_outline"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_delete_sel"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/delete_selected"
            android:textColor="@color/neon_red"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_outline"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="14dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/empty_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/free_empty"
            android:textColor="?attr/appTextDim"
            android:textSize="14sp" />
    </FrameLayout>
</LinearLayout>
