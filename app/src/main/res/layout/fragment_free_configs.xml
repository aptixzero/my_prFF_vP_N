<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="18dp"
    android:paddingTop="12dp"
    android:paddingBottom="14dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/free_title"
        android:textColor="@color/violet_bright"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:shadowColor="@color/violet"
        android:shadowDx="0" android:shadowDy="0" android:shadowRadius="20" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/free_hint"
        android:textColor="?attr/appTextSecondary"
        android:textSize="11sp"
        android:layout_marginTop="3dp" />

    <!-- START SEARCH bar (search-input style with magnifier) -->
    <LinearLayout
        android:id="@+id/btn_search"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="14dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/connect_pill_idle"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            app:tint="#FFFFFFFF"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/btn_search_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/start_search"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <!-- Action row: PING ALL (primary) · AUTO TEST (warning) · DELETE ALL (danger) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:weightSum="3">

        <TextView
            android:id="@+id/btn_ping_all"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/ping_all"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_secondary"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_auto_test"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/auto_test"
            android:textColor="@color/state_warning"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_warning"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_delete_all"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/delete_all"
            android:textColor="@color/state_danger"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_danger"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- progress bar + label (visible during search / auto-test) -->
    <LinearLayout
        android:id="@+id/progress_box"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/search_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/neon_progress" />

        <TextView
            android:id="@+id/progress_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text=""
            android:textColor="?attr/appTextSecondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- List header: AVAILABLE CONFIGS (n) · SELECT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="14dp">

        <TextView
            android:id="@+id/list_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AVAILABLE CONFIGS"
            android:textColor="?attr/appTextSecondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/btn_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_mode"
            android:textColor="@color/violet_bright"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:background="@drawable/btn_outline"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Select-mode toolbar (hidden until select on) -->
    <LinearLayout
        android:id="@+id/select_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:weightSum="3"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_select_all"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/select_all"
            android:textColor="@color/violet_bright"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_outline"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_copy_sel"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/copy_selected"
            android:textColor="@color/violet_bright"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_outline"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_delete_sel"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/delete_selected"
            android:textColor="@color/state_danger"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/btn_outline"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/empty_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/free_empty"
            android:textColor="?attr/appTextDim"
            android:textSize="14sp" />
    </FrameLayout>
</LinearLayout>
