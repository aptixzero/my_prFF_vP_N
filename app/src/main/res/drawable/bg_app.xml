<?xml version="1.0" encoding="utf-8"?>
<!-- Premium dark-cyber app background: pure black with restrained violet blooms.
     No photo, no matrix, no flashing — just soft depth + a thin top accent. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- solid pure-black base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF000000" />
        </shape>
    </item>
    <!-- top-center violet bloom (subtle) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="520dp"
                android:centerX="0.5"
                android:centerY="-0.08"
                android:startColor="#26A855F7"
                android:endColor="#00000000" />
        </shape>
    </item>
    <!-- bottom-right indigo bloom (very subtle) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="460dp"
                android:centerX="0.95"
                android:centerY="1.05"
                android:startColor="#1A818CF8"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
