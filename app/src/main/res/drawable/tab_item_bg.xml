<?xml version="1.0" encoding="utf-8"?>
<!-- Tab item: subtle violet glow + bright violet underline when selected. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="90"
                        android:startColor="#00000000"
                        android:endColor="#26A855F7" />
                </shape>
            </item>
            <item android:gravity="bottom" android:height="2.5dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/violet_bright" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:drawable="@android:color/transparent" />
</selector>
