<?xml version="1.0" encoding="utf-8"?>
<!-- App background (light theme): responsive photo + soft bloom overlays. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/lbg_deep" />
        </shape>
    </item>
    <item>
        <bitmap
            android:src="@drawable/bg_image_light"
            android:gravity="fill" />
    </item>
    <!-- gentle lightening scrim for readability -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#55FFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="420dp"
                android:centerX="0.92"
                android:centerY="0.05"
                android:startColor="#2200A847"
                android:endColor="#00000000" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="420dp"
                android:centerX="0.06"
                android:centerY="0.95"
                android:startColor="#16D81534"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
