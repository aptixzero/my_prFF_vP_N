<?xml version="1.0" encoding="utf-8"?>
<!-- Server row card: dark glass + thin white hairline; violet rim when selected. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/bg_card_active" />
            <stroke android:width="1.4dp" android:color="@color/violet" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/bg_card" />
            <stroke android:width="1dp" android:color="@color/hairline" />
        </shape>
    </item>
</selector>
