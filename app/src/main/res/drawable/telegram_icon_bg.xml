<!--
  Circular "glass" plate behind the home-screen Telegram icon. Black core with a
  violet hairline + soft violet inner glow so the icon matches the app's
  purple/black cyber theme (NOT Telegram blue) and looks built-in.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- soft violet outer glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#33A855F7" />
            <size android:width="44dp" android:height="44dp" />
        </shape>
    </item>
    <!-- black glass disc with a violet hairline rim -->
    <item
        android:top="3dp" android:bottom="3dp"
        android:left="3dp" android:right="3dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="22dp"
                android:startColor="#FF17121F"
                android:centerColor="#FF0C0912"
                android:endColor="#FF050507" />
            <stroke android:width="1dp" android:color="#88A855F7" />
        </shape>
    </item>
</layer-list>
