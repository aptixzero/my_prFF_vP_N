<?xml version="1.0" encoding="utf-8"?>
<!-- Connected state: layered neon-green gaming glow ring. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- outer radial green bloom -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="210dp"
                android:startColor="#6600FF66"
                android:centerColor="#2200FF66"
                android:endColor="#00000000" />
        </shape>
    </item>
    <!-- mid solid faint green halo -->
    <item android:left="14dp" android:top="14dp" android:right="14dp" android:bottom="14dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#3300FF66" />
        </shape>
    </item>
    <!-- bright dashed rotating ring -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="3dp"
                android:color="@color/neon_green"
                android:dashWidth="24dp"
                android:dashGap="9dp" />
        </shape>
    </item>
    <!-- inner thin bright accent ring -->
    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="oval">
            <stroke android:width="1.5dp" android:color="#AA39FF9E" />
        </shape>
    </item>
</layer-list>
