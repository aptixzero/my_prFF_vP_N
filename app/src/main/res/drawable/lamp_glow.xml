<?xml version="1.0" encoding="utf-8"?>
<!-- Radial lamp glow shown behind the vertical switch. State-driven. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="160dp"
                android:startColor="#5500FF66"
                android:centerColor="#2200FF66"
                android:endColor="#0000FF66" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="160dp"
                android:startColor="#22FF1E3C"
                android:centerColor="#11FF1E3C"
                android:endColor="#00FF1E3C" />
        </shape>
    </item>
</selector>
