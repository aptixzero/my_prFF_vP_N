<?xml version="1.0" encoding="utf-8"?>
<!-- DANGER button: dark fill, thin red border, red text. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#22EF4444" />
            <stroke android:width="1.4dp" android:color="@color/state_danger" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#FF0B0816" />
            <stroke android:width="1.2dp" android:color="@color/state_danger" />
        </shape>
    </item>
</selector>
