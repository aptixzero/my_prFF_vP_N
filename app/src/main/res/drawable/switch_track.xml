<?xml version="1.0" encoding="utf-8"?>
<!-- Vertical switch track (the slot the knob slides in). Pill shaped. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- ON (activated): bright neon-green energised slot -->
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <corners android:radius="60dp" />
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#FF00FF66"
                android:centerColor="#FF00C24E"
                android:endColor="#FF00351B" />
            <stroke android:width="2dp" android:color="#CC00FF66" />
        </shape>
    </item>
    <!-- OFF: dim dark slot -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="60dp" />
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#FF161B17"
                android:centerColor="#FF0D110E"
                android:endColor="#FF050806" />
            <stroke android:width="2dp" android:color="#44FF1E3C" />
        </shape>
    </item>
</selector>
