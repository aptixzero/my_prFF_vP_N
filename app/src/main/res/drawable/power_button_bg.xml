<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="80dp"
                android:startColor="#FF00FF66"
                android:centerColor="#FF00C24E"
                android:endColor="#FF005226" />
            <stroke android:width="2dp" android:color="#CC00FF66" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="80dp"
                android:startColor="#FF0C140E"
                android:centerColor="#FF080D09"
                android:endColor="#FF030503" />
            <stroke android:width="1.5dp" android:color="#5500FF66" />
        </shape>
    </item>
</selector>
