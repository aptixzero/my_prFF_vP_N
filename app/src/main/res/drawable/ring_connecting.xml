<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="170dp"
                android:startColor="#33CFFF00"
                android:endColor="#00000000" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="@color/neon_yellow"
                android:dashWidth="14dp"
                android:dashGap="10dp" />
        </shape>
    </item>
</layer-list>
