<?xml version="1.0" encoding="utf-8"?>
<!-- SECONDARY button: dark gray-violet fill, thin purple border. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#FF160E28" />
            <stroke android:width="1dp" android:color="@color/violet" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#FF0E0A1A" />
            <stroke android:width="1dp" android:color="@color/card_border_lite" />
        </shape>
    </item>
</selector>
