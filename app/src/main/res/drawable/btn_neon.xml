<?xml version="1.0" encoding="utf-8"?>
<!-- Premium primary button: deep violet gradient with a thin bright-violet rim. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <corners android:radius="16dp" />
    <gradient
        android:type="linear"
        android:angle="90"
        android:startColor="#FFB163FF"
        android:centerColor="@color/violet"
        android:endColor="@color/violet_deep" />
    <stroke android:width="1dp" android:color="#55FFFFFF" />
</shape>
