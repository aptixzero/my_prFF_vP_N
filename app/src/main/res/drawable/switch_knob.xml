<?xml version="1.0" encoding="utf-8"?>
<!-- The sliding knob of the vertical lamp switch. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="44dp"
                android:startColor="#FFFFFFFF"
                android:centerColor="#FFB6FFD2"
                android:endColor="#FF00C24E" />
            <stroke android:width="2dp" android:color="#FFEFFFF5" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="44dp"
                android:startColor="#FF2A322C"
                android:centerColor="#FF1A201C"
                android:endColor="#FF0B0F0C" />
            <stroke android:width="2dp" android:color="#55FF1E3C" />
        </shape>
    </item>
</selector>
