<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ProfessorVPN" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="colorPrimary">@color/violet</item>
        <item name="colorPrimaryVariant">@color/violet_deep</item>
        <item name="colorAccent">@color/violet_bright</item>
        <item name="colorOnPrimary">#FFFFFFFF</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="alertDialogTheme">@style/Theme.ProfessorVPN.Dialog</item>
        <item name="materialAlertDialogTheme">@style/Theme.ProfessorVPN.Dialog</item>
        <!-- semantic theme attributes -->
        <item name="appBgColor">@color/bg_deep</item>
        <item name="appPanelColor">@color/bg_panel</item>
        <item name="appCardColor">@color/bg_card</item>
        <item name="appCardActiveColor">@color/bg_card_active</item>
        <item name="appTextPrimary">@color/text_primary</item>
        <item name="appTextSecondary">@color/text_secondary</item>
        <item name="appTextDim">@color/text_dim</item>
        <item name="appAccentGreen">@color/neon_green</item>
        <item name="appAccentRed">@color/neon_red</item>
        <item name="appStroke">@color/stroke</item>
        <item name="appBgDrawable">@drawable/bg_app</item>
    </style>

    <!-- LIGHT theme — same neon brand accents, light surfaces. -->
    <style name="Theme.ProfessorVPN.Light" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/lbg_deep</item>
        <item name="colorPrimary">@color/lneon_green</item>
        <item name="colorPrimaryVariant">@color/lneon_green</item>
        <item name="colorAccent">@color/lneon_red</item>
        <item name="colorOnPrimary">#FFFFFFFF</item>
        <item name="android:statusBarColor">@color/lbg_deep</item>
        <item name="android:navigationBarColor">@color/lbg_deep</item>
        <item name="android:textColorPrimary">@color/ltext_primary</item>
        <item name="android:textColorSecondary">@color/ltext_secondary</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="alertDialogTheme">@style/Theme.ProfessorVPN.Dialog.Light</item>
        <item name="materialAlertDialogTheme">@style/Theme.ProfessorVPN.Dialog.Light</item>
        <!-- semantic theme attributes -->
        <item name="appBgColor">@color/lbg_deep</item>
        <item name="appPanelColor">@color/lbg_panel</item>
        <item name="appCardColor">@color/lbg_card</item>
        <item name="appCardActiveColor">#FFE2F7E9</item>
        <item name="appTextPrimary">@color/ltext_primary</item>
        <item name="appTextSecondary">@color/ltext_secondary</item>
        <item name="appTextDim">@color/ltext_dim</item>
        <item name="appAccentGreen">@color/lneon_green</item>
        <item name="appAccentRed">@color/lneon_red</item>
        <item name="appStroke">#FFCAD9CF</item>
        <item name="appBgDrawable">@drawable/bg_app_light</item>
    </style>

    <!-- Splash uses the dark base regardless (brand boot screen). -->
    <style name="Theme.ProfessorVPN.Splash" parent="Theme.ProfessorVPN" />

    <!-- Neon dark dialog for the Auto-Test confirmation, etc. -->
    <style name="Theme.ProfessorVPN.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:windowBackground">@drawable/dialog_bg</item>
        <item name="colorPrimary">@color/neon_green</item>
        <item name="colorAccent">@color/neon_green</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.ProfessorVPN.Button.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.ProfessorVPN.Button.Negative</item>
    </style>

    <style name="Theme.ProfessorVPN.Dialog.Light" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/lneon_green</item>
        <item name="colorAccent">@color/lneon_green</item>
        <item name="android:textColorPrimary">@color/ltext_primary</item>
        <item name="android:textColorSecondary">@color/ltext_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.ProfessorVPN.Button.Positive.Light</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.ProfessorVPN.Button.Negative</item>
    </style>

    <style name="Widget.ProfessorVPN.Button.Positive" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/neon_green</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.ProfessorVPN.Button.Positive.Light" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/lneon_green</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.ProfessorVPN.Button.Negative" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/neon_red</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Backwards-compatible alias -->
    <style name="Theme.NeonVPN" parent="Theme.ProfessorVPN" />
</resources>
