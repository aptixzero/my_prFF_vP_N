<resources>
    <!-- ============================================================= -->
    <!-- Professor VPN — v4.0 "VPN UI SHEET" palette                    -->
    <!-- Pure-black base, violet/purple neon accents, green=connected,  -->
    <!-- amber=warning, magenta/red=danger. Matches the design sheet.   -->
    <!-- ============================================================= -->

    <!-- Surfaces: pure black → dark navy/violet glass tiers -->
    <color name="bg_deep">#FF000000</color>
    <color name="bg_panel">#FF06040C</color>
    <color name="bg_card">#FF0B0816</color>
    <color name="bg_card_active">#FF160E28</color>
    <color name="card_border">#FF1C162E</color>
    <color name="card_border_lite">#FF272042</color>

    <!-- Primary accent = neon violet (the sheet's signature colour). -->
    <color name="neon_green">#FF8A3FFC</color>      <!-- semantic "go"  -> violet (legacy alias) -->
    <color name="neon_green_dim">#FF4C2896</color>
    <color name="neon_red">#FFEF4444</color>        <!-- semantic "alert" -> red -->
    <color name="neon_red_dim">#FFDC2626</color>

    <!-- Accent ramp -->
    <color name="neon_cyan">#FF8A3FFC</color>       <!-- alias -> violet -->
    <color name="neon_magenta">#FFC026D3</color>
    <color name="neon_purple">#FFB983FF</color>
    <color name="neon_blue">#FF818CF8</color>
    <color name="neon_yellow">#FFF59E0B</color>

    <!-- Brand violet ramp -->
    <color name="violet">#FF8A3FFC</color>
    <color name="violet_bright">#FFB983FF</color>
    <color name="violet_deep">#FF4C2896</color>
    <color name="violet_darker">#FF311B61</color>
    <color name="violet_glow">#668A3FFC</color>

    <!-- Semantic state colours (connected / warning / danger) -->
    <color name="state_connected">#FF10B981</color>
    <color name="state_connected_dim">#FF059669</color>
    <color name="state_warning">#FFF59E0B</color>
    <color name="state_danger">#FFEF4444</color>

    <!-- Ping latency colours (sheet: green<50 / amber 51-100 / red>100) -->
    <color name="ping_fast">#FF10B981</color>
    <color name="ping_med">#FFF59E0B</color>
    <color name="ping_slow">#FFEF4444</color>

